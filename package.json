{
  "name": "embedded-board-config",
  "displayName": "Embedded Board Config",
  "description": "Manage embedded board, serial port, build output, monitor and profiles from VS Code.",
  "version": "0.2.0",
  "publisher": "baoshan",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "activationEvents": [
      "onCommand:embeddedBoardConfig.openPanel",
      "onCommand:embeddedBoardConfig.validateConfig",
      "onCommand:embeddedBoardConfig.openConfigFile",
      "onCommand:embeddedBoardConfig.compileSketch",
      "onCommand:embeddedBoardConfig.uploadSketch",
      "onView:embeddedBoardConfig.sidebar"
    ],
    "commands": [
      {
        "command": "embeddedBoardConfig.openPanel",
        "title": "Embedded Board Config: Open Panel"
      },
      {
        "command": "embeddedBoardConfig.validateConfig",
        "title": "Embedded Board Config: Validate Current Config"
      },
      {
        "command": "embeddedBoardConfig.openConfigFile",
        "title": "Embedded Board Config: Open Config File"
      },
      {
        "command": "embeddedBoardConfig.compileSketch",
        "title": "Embedded Board Config: Compile Sketch"
      },
      {
        "command": "embeddedBoardConfig.uploadSketch",
        "title": "Embedded Board Config: Upload Sketch"
      },
      {
        "command": "embeddedBoardConfig.refreshSidebar",
        "title": "Embedded Board Config: Refresh Sidebar",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "embeddedBoardConfig",
          "title": "Embedded Board Config",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "embeddedBoardConfig": [
        {
          "id": "embeddedBoardConfig.sidebar",
          "name": "配置概览"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "embeddedBoardConfig.refreshSidebar",
          "when": "view == embeddedBoardConfig.sidebar",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "embeddedBoardConfig.openPanel",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus"
      },
      {
        "command": "embeddedBoardConfig.validateConfig",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      },
      {
        "command": "embeddedBoardConfig.compileSketch",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus"
      },
      {
        "command": "embeddedBoardConfig.uploadSketch",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --allow-missing-repository",
    "test": "npm run compile && mocha \"dist/test/**/*.test.js\"",
    "test:watch": "tsc -w -p ./ & mocha --watch \"dist/test/**/*.test.js\"",
    "install:vsix": "powershell -ExecutionPolicy Bypass -File .\\install-vsix.ps1",
    "install:vsix:trae": "powershell -ExecutionPolicy Bypass -File .\\install-vsix.ps1 -Ide trae",
    "install:vsix:code": "powershell -ExecutionPolicy Bypass -File .\\install-vsix.ps1 -Ide code"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.9.2",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "sinon": "^21.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
